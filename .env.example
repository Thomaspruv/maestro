APP_NAME=Maestro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=maestro
DB_USERNAME=maestro
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=maestro
PUSHER_APP_KEY=maestro-key
PUSHER_APP_SECRET=maestro-secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# GitHub OAuth — identifiants de l'APPLICATION Maestro (une fois par déploiement).
# Chaque utilisateur connecte ensuite SON compte via Paramètres → GitHub.
# Créer une OAuth App : https://github.com/settings/developers
# Callback URL : {APP_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# En local, Maestro utilise un token personnel par défaut (pas de callback localhost).
# Valeurs : auto | pat | oauth
GITHUB_AUTH=auto
# Mettre true pour forcer OAuth en local (ex. tunnel ngrok vers /auth/github/callback)
GITHUB_OAUTH_IN_LOCAL=false
# Template pour créer un nouveau repo depuis le wizard (owner/repo). Laisser vide pour désactiver.
# MAESTRO_GITHUB_TEMPLATE_REPO=Thomaspruv/maestro-template

# Agent Dev : exécution déléguée à Hermes via MCP (voir docs/DEPLOYMENT.md)
# Timeouts API Anthropic (secondes) — agents pipeline et Discovery
ANTHROPIC_TIMEOUT=180
ANTHROPIC_DISCOVERY_TIMEOUT=180
MAESTRO_DISCOVERY_MAX_HISTORY=10
MAESTRO_AGENT_OUTPUT_MAX_CHARS=8000
MAESTRO_AGENT_JOB_TRIES=2
MAESTRO_QUEUE_RETRY_AFTER=960
MAESTRO_QUEUE_WORKER_TIMEOUT=960

# Bases protégées contre migrate:fresh / db:wipe en local (séparées par des virgules)
MAESTRO_PROTECTED_DB_NAMES=maestro
# Autoriser migrate:fresh / db:wipe sur la base dev (opt-in explicite)
# MAESTRO_ALLOW_DESTRUCTIVE_DB=true

# MAESTRO_GITHUB_TEMPLATE_REPO=Thomaspruv/maestro-template

# OAuth MCP (Claude Cowork) — TTL en secondes
# MAESTRO_MCP_ACCESS_TOKEN_TTL=3600
# MAESTRO_MCP_REFRESH_TOKEN_TTL=2592000

# Secret pour vérifier les webhooks GitHub (optionnel)
GITHUB_WEBHOOK_SECRET=

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
